<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EDIZ.WIN</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#090909;
color:#fff;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px;
background:#111;
border-bottom:2px solid #c8a34a;
position:sticky;
top:0;
z-index:1000;
}

.logo{
font-size:38px;
font-weight:bold;
color:#FFD700;
text-shadow:0 0 10px gold,0 0 25px #b8860b;
}

.menu a{
text-decoration:none;
color:#000;
background:linear-gradient(#FFD700,#B8860B);
padding:12px 22px;
margin-left:10px;
border-radius:10px;
font-weight:bold;
}

.hero{
padding:70px 20px;
text-align:center;
background:linear-gradient(180deg,#111,#000);
}

.hero h1{
font-size:55px;
color:#FFD700;
margin-bottom:15px;
}

.hero p{
font-size:20px;
color:#ddd;
margin-bottom:25px;
}

.hero button{
background:linear-gradient(#FFD700,#b8860b);
border:none;
padding:18px 40px;
font-size:20px;
font-weight:bold;
border-radius:15px;
cursor:pointer;
}

.section{
padding:45px 20px;
}

.section h2{
color:#FFD700;
margin-bottom:25px;
font-size:32px;
}

.social-card{
display:flex;
justify-content:space-between;
align-items:center;
background:#161616;
padding:20px;
margin-bottom:18px;
border-radius:15px;
text-decoration:none;
color:white;
transition:.3s;
border:1px solid #2a2a2a;
}

.social-card:hover{
background:#242424;
}

.social-title{
font-size:22px;
font-weight:bold;
}

.partner-grid{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:18px;
}

.partner{
background:#161616;
padding:25px;
border-radius:15px;
border:1px solid #2d2d2d;
text-align:center;
}

.partner img{
width:70px;
margin-bottom:15px;
}

.partner h3{
color:#FFD700;
margin-bottom:10px;
}

table{
width:100%;
border-collapse:collapse;
margin-top:20px;
}

th{
background:#d8af39;
color:#000;
padding:14px;
}

td{
padding:14px;
border-bottom:1px solid #2b2b2b;
}

footer{
padding:35px;
text-align:center;
color:#999;
}

</style>

</head>

<body>

<header>

<div class="logo">👑 EDIZ</div>

<div class="menu">
<a href="#">Giriş Yap</a>
<a href="#">Kayıt Ol</a>
</div>

</header>

<section class="hero">

<h1>EDIZ.WIN</h1>

<p>Premium Casino Partner Platformu</p>

<button>HEMEN BAŞLA</button>

</section>
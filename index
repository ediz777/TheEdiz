<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>EDIZ.WIN</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{
background:#0b0b0b;
color:#fff;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px;
background:#111;
border-bottom:1px solid #333;
}

.logo{
font-size:34px;
font-weight:bold;
color:#FFD700;
text-shadow:
0 0 8px gold,
0 0 20px #b8860b;
}

.menu{
display:flex;
gap:12px;
}

.btn{
padding:12px 24px;
border-radius:10px;
background:linear-gradient(180deg,#FFD700,#b8860b);
color:#000;
text-decoration:none;
font-weight:bold;
transition:.3s;
}

.btn:hover{
transform:scale(1.05);
}

.hero{
padding:70px 20px;
text-align:center;
}

.hero h1{
font-size:48px;
color:#FFD700;
margin-bottom:20px;
}

.hero p{
font-size:20px;
color:#ddd;
margin-bottom:30px;
}

.bigButton{
display:inline-block;
padding:18px 45px;
background:linear-gradient(180deg,#FFD700,#a97900);
border-radius:15px;
text-decoration:none;
color:#000;
font-size:22px;
font-weight:bold;
}

.section{
padding:40px 20px;
}

.section h2{
font-size:30px;
margin-bottom:25px;
color:#FFD700;
}

.social{
display:flex;
flex-direction:column;
gap:18px;
}

.card{
background:#151515;
padding:20px;
border-radius:15px;
border:1px solid #333;
display:flex;
justify-content:space-between;
align-items:center;
transition:.3s;
text-decoration:none;
color:white;
}

.card:hover{
background:#202020;
}

.card span{
font-size:20px;
}

.partnerGrid{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:20px;
}

.partner{
background:#181818;
padding:25px;
border-radius:15px;
text-align:center;
border:1px solid #333;
}

.partner h3{
color:#FFD700;
margin-bottom:15px;
}

.partner p{
color:#ccc;
}

table{
width:100%;
border-collapse:collapse;
margin-top:20px;
}

th{
background:#FFD700;
color:black;
padding:15px;
}

td{
padding:15px;
border-bottom:1px solid #333;
text-align:center;
}

footer{
padding:40px;
text-align:center;
color:#999;
}

</style>
</head>

<body>

<header>

<div class="logo">👑 EDIZ</div>

<div class="menu">
<a href="#" class="btn">Giriş Yap</a>
<a href="#" class="btn">Kayıt Ol</a>
</div>

</header>

<section class="hero">

<h1>EDIZ.WIN</h1>

<p>Premium Casino Partner Platformu</p>

<a class="bigButton" href="#">HEMEN BAŞLA</a>

</section>